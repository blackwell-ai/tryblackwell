# Copy to .env.local and fill in. .env*.local is gitignored.

# --- Supabase (from the project's API settings) ---
# Public values (safe to expose to the browser):
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only values (NEVER expose to the browser / commit):
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Anthropic (AI tag synthesis + reviewer/brand matching) ---
# Server-only. Used by app/api/* routes via @anthropic-ai/sdk.
ANTHROPIC_API_KEY=

# --- Stripe (existing checkout route) ---
STRIPE_KEY=

# --- Giftly (source DB for the reviewer/brand sync: scripts/migrate-giftly.ts) ---
# Server-only. GIFTLY_SECRET_KEY is Giftly's sb_secret_... key (bypasses RLS to
# read creators/brands). Only needed to run `pnpm migrate:giftly`.
GIFTLY_SUPABASE_URL=
GIFTLY_SECRET_KEY=
